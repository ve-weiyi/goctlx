syntax = "v1"

type (
    FileInfoVO {
        FilePath string `json:"file_path"`  // 文件路径
        FileName string `json:"file_name"`  // 文件名称
        FileType string `json:"file_type"`  // 文件类型
        FileSize int64 `json:"file_size"`   // 文件大小
        FileUrl string `json:"file_url"`    // 上传路径
        UpdatedAt int64 `json:"updated_at"` // 更新时间
    }
    UploadFileReq {
        File interface{} `form:"file,optional"`     // 文件
        FilePath string `form:"file_path,optional"` // 文件路径
    }
    MultiUploadFilesReq {
        Files []interface{} `form:"files,optional"` // 文件列表
        FilePath string `form:"file_path,optional"` // 文件路径
    }
    ListFileReq {
        FilePath string `json:"file_path,optional"` // 文件路径
        Limit int64 `json:"limit,optional"`         // 限制
    }
    ListUploadFileReq {
        FilePaths []string `json:"file_paths,optional"` // 文件路径
    }

    FileReq {

    }

    DeleteFileReq {
        Id string `path:"id" validate:"required"`
    }
    DeleteFileResp {
        Success bool `json:"success"`
    }
    BatchDeleteFilesReq {
        Ids []string `json:"ids" validate:"required,min=1"`
    }
    BatchDeleteFilesResp {
        SuccessCount int64 `json:"success_count"`
    }
)

@server(
    tags: "文件管理"
    prefix:     /admin-api/v1
    group: file
    middleware: AdminAuth
    maxBytes:   10485760
)
service admin-api {
    @doc "上传文件"
    @handler UploadFile
    post /files (UploadFileReq) returns (FileInfoVO)

    @doc "上传文件列表"
    @handler MultiUploadFiles
    post /files/multi (MultiUploadFilesReq) returns ([]*FileInfoVO)

    @doc "获取文件列表"
    @handler ListFile
    post /files/list (ListFileReq) returns ([]*FileInfoVO)

    @doc "批量删除文件"
    @handler DeleteFile
    delete /files/:id (DeleteFileReq) returns (DeleteFileResp)

    @doc "批量删除文件"
    @handler BatchDeleteFile
    delete /files/batch-delete (BatchDeleteFilesReq) returns (BatchDeleteFilesResp)
}

